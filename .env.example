# Convex writes these values to .env.local during development.
# In Vercel, set the production/preview values in Project Settings > Environment Variables.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# For Vercel builds that deploy Convex functions, add CONVEX_DEPLOY_KEY in Vercel only.
# Do not commit real deploy keys.
CONVEX_DEPLOY_KEY=
